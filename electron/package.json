{
  "name": "arynox-edu-desktop",
  "version": "1.0.0",
  "description": "Arynox-EDU Windows Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.arynoxtech.education",
    "productName": "Arynox-EDU",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!release/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "../public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Arynox-EDU"
    }
  }
}